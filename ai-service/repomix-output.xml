<file path="app/api/chat.py">
from fastapi import APIRouter, Request
from pydantic import BaseModel
from app.graph.builder import agent
from langchain_core.messages import HumanMessage

router = APIRouter()

class ChatRequest(BaseModel):
    message: str

@router.post("/chat")
async def chat_endpoint(request: ChatRequest):
    
    user_input = request.message
    # Here you would typically call your chat model or service
    # For demonstration, we'll just echo the user input
    initial_state= {
    'messages': [HumanMessage(content= user_input)]
}
    chat_response = agent.invoke(initial_state)
        
    response_content = chat_response['messages'][-1].content[0]['text']

    return {"response": response_content}
</file>

<file path="app/graph/builder.py">
from langgraph.graph import StateGraph, START, END
from app.graph.nodes import Chatbot
from app.graph.state import AgentState

graph = StateGraph(AgentState)

graph.add_node('chatbot', Chatbot)

graph.add_edge(START, 'chatbot')
graph.add_edge('chatbot', END)

agent= graph.compile()
</file>

<file path="app/graph/nodes.py">
from app.graph.state import AgentState
from app.services.gemini import get_llm

def Chatbot(state: AgentState)->AgentState:
    messages = state['messages']
    
    response = get_llm.invoke(messages)
    
    return {'messages': [response]}
</file>

